<header class="bg-orange-50 shadow-sm border-b border-amber-100">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between">
    <div class="flex items-center">
      <%= link_to root_path, class: "flex items-center" do %>
        <span class="text-2xl mr-2">🍫</span>
        <h1 class="text-xl font-bold text-amber-900">ショコラの記憶</h1>
      <% end %>
    </div>
    
    <div class="flex items-center gap-4">
      <!-- ログインしている時 -->
      <% if user_signed_in? %>
        <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "bg-amber-900 text-white px-4 py-2 rounded-md text-sm hover:bg-amber-800" %>
      <% else %>
        <!-- ログイン前でユーザー登録画面にいる時 -->
        <% if current_page?(new_user_registration_path) %>
          <%= link_to "ログイン", new_user_session_path, class: "bg-amber-900 text-white px-4 py-2 rounded-md text-sm hover:bg-amber-800" %>
        <!-- ログイン画面にいる時 -->
        <% elsif current_page?(new_user_session_path) %>
          <%= link_to "新規登録", new_user_registration_path, class: "bg-amber-900 text-white px-4 py-2 rounded-md text-sm hover:bg-amber-800" %>
        <!-- それ以外はどちらも表示 -->
        <% else %>
          <%= link_to "新規登録", new_user_registration_path, class: "bg-amber-900 text-white px-4 py-2 rounded-md text-sm hover:bg-amber-800" %>
          <%= link_to "ログイン", new_user_session_path, class: "bg-amber-900 text-white px-4 py-2 rounded-md text-sm hover:bg-amber-800" %> 
        <% end %>
      <% end %>
    </div>
  </nav>
</header>
