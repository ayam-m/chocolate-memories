<div class="sm:w-full sm:mx-auto sm:max-w-md p-4">
  <div class="bg-white py-8 px-4 shadow rounded-md sm:px-10">
    <h2 class="mb-8 text-center text-3xl font-extrabold">ログイン</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <%= render "shared/error_messages", object: resource %>

      <div class="field">
        <p><%= f.label :email %></p>
        <p><%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full border border-gray-400 rounded px-3 py-2 mb-6" %></p>
      </div>

      <div class="field">
        <p><%= f.label :password %></p>
        <p><%= f.password_field :password, autocomplete: "current-password",
              class: "w-full border border-gray-400 rounded px-3 py-2 mb-6" %></p>
      </div>

      <!-- <% if devise_mapping.rememberable? %>
        <div class="field flex items-center gap-x-2">
          <p><%= f.check_box :remember_me %></p>
          <p><%= f.label :remember_me %></p>
        </div>
      <% end %> -->

      <div class="actions">
        <%= f.submit "ログイン", 
            class: "w-full bg-amber-900 text-white px-4 py-2 my-6 rounded-lg text-sm hover:bg-amber-800 cursor-pointer" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>