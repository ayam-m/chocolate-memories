<div class="sm:w-full sm:mx-auto sm:max-w-md p-4">
  <div class="bg-white py-8 px-4 shadow rounded-md sm:px-10">
    <h2 class="mb-8 text-center text-3xl font-extrabold">アカウント登録</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "shared/error_messages", object: resource %>

      <div class="field">
        <p><%= f.label :email %></p>
        <p><%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full border border-gray-400 rounded px-3 py-2 mb-6" %></p>
      </div>

      <div class="field">
        <p><%= f.label :password, "パスワード（6文字以上でご登録ください）" %></p>
        <p><%= f.password_field :password, autocomplete: "new-password",
              class: "w-full border border-gray-400 rounded px-3 py-2 mb-6" %></p>
      </div>

      <div class="field">
        <p><%= f.label :password_confirmation %></p>
        <p><%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "w-full border border-gray-400 rounded px-3 py-2 mb-6" %></p>
      </div>

      <div class="actions">
        <%= f.submit "登録", 
            class: "w-full bg-amber-900 text-white px-4 py-2 my-6 rounded-lg text-sm hover:bg-amber-800 cursor-pointer" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>