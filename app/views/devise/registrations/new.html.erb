<div class="min-h-screen flex flex-col justify-center lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h2 class="mb-4 text-center text-3xl font-extrabold">アカウント登録</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="field">
      <p><%= f.label :email %></p>
      <p><%= f.email_field :email, autofocus: true, autocomplete: "email",
             class: "border border-gray-400 rounded px-3 py-2 mb-6 w-md" %></p>
    </div>

    <div class="field">
      <p><%= f.label :password, "パスワード（6文字以上でご登録ください）" %></p>
      <p><%= f.password_field :password, autocomplete: "new-password",
             class: "border border-gray-400 rounded px-3 py-2 mb-6 w-md" %></p>
    </div>

    <div class="field">
      <p><%= f.label :password_confirmation %></p>
      <p><%= f.password_field :password_confirmation, autocomplete: "new-password",
             class: "border border-gray-400 rounded px-3 py-2 mb-6 w-md" %></p>
    </div>

    <div class="actions">
      <%= f.submit "登録", 
          class: "bg-amber-900 text-white px-4 py-2 my-5 rounded-lg w-md text-sm hover:bg-amber-800" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
  </div>
</div>