<div class="w-full max-w-5xl mx-auto p-4">
  <div id="record-<%= @record.id %>">

    <!--詳細表示 大きな白い余白を確保 -->
    <div class="relative h-auto bg-gray-100 p-4 shadow-xl border border-gray-200 grid grid-cols-1 md:grid-cols-[1fr_1.5fr] gap-6 rounded-lg items-start">
      
      <!-- 左側：画像表示 -->
      <div class="w-full bg-gray-100 flex items-center justify-center shadow-lg rounded-lg sticky top-4">
        <%= image_tag switch_image_path(@record.image, 800, 800), class: "max-w-full h-auto object-contain rounded-lg" %>
      </div>

      <!-- 右側：テキスト -->
      <div class="flex flex-col px-2 min-w-0">
        <ul class="mt-6 space-y-4 text-xl font-bold">
          <% if @record.record_type == "gifted" %>
            <li>贈答日: <%= @record.event_date %></li>
            <li>宛名: <%= @record&.recipient_name %></li>
          <% else %>
            <li>実食日: <%= @record.event_date %></li>
          <% end %>

          <li class="mb-8">ブランド名: <%= @record.brand&.name%></li>

          <% if @record.record_type == "eaten" %>
            <li class="flex">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="m18.375 12.739-7.693 7.693a4.5 4.5 0 0 1-6.364-6.364l10.94-10.94A3 3 0 1 1 19.5 7.372L8.552 18.32m.009-.01-.01.01m5.699-9.941-7.81 7.81a1.5 1.5 0 0 0 2.112 2.13" />
              </svg>
              甘さ: <%= Tasting::SWEETNESS_OPTS[@record.tasting&.sweetness] %>
            </li>
            <li class="flex">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="m18.375 12.739-7.693 7.693a4.5 4.5 0 0 1-6.364-6.364l10.94-10.94A3 3 0 1 1 19.5 7.372L8.552 18.32m.009-.01-.01.01m5.699-9.941-7.81 7.81a1.5 1.5 0 0 0 2.112 2.13" />
              </svg>
              濃厚さ: <%= Tasting::RICHNESS_OPTS[@record.tasting&.richness] %>
            </li>
            <li class="flex">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="m18.375 12.739-7.693 7.693a4.5 4.5 0 0 1-6.364-6.364l10.94-10.94A3 3 0 1 1 19.5 7.372L8.552 18.32m.009-.01-.01.01m5.699-9.941-7.81 7.81a1.5 1.5 0 0 0 2.112 2.13" />
              </svg>
              口どけ: <%= Tasting::MELTING_OPTS[@record.tasting&.melting] %>
            </li>
          <% end %>

          <!-- メモが長い時に見た目が悪くならないよう改行して表示 -->
          <li class="mt-8 flex flex-col">
            <span class="text-xl font-bold">メモ:</span>
            <div class="ml-4 font-normal text-lg" style="word-break: break-all; overflow-wrap: anywhere; white-space: pre-wrap;"><%= @record&.memo %></div>
          </li>
        </ul>

        <!-- 編集ボタン -->
        <div class="absolute top-6 right-6">
          <%= link_to edit_record_path(@record), class: "flex flex-col items-center justify-center w-14 h-14 rounded-md text-amber-700 hover:bg-orange-200 transition-all duration-300" do %>
            <span class="text-xs mb-1 font-bold">編集</span> 
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-9">
              <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
            </svg>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
