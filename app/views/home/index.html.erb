<div class="w-full max-w-5xl mx-auto px-4 ">
  <section class="bg-orange-50 rounded-lg px-6 py-8 max-w-4xl mx-auto space-y-5">
    <h1 class="text-center text-4xl text-amber-900 font-bold mt-4">ショコラの記憶</h1>
    <p class="text-center text-lg text-gray-700">チョコ好きさんのための、チョコの思い出記録アプリ</p>

    <!-- 簡単な使用方法 -->
    <div class="flex flex-wrap gap-5 p-6 justify-center items-center">
      <div class="grid grid-cols-2 gap-5 max-w-3xl mt-8">
        <div class="border border-slate-200 rounded-xl shadow-sm px-4 py-3 space-y-5 ">
          <div class="flex gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L6.832 19.82a4.5 4.5 0 0 1-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 0 1 1.13-1.897L16.863 4.487Zm0 0L19.5 7.125" />
            </svg>
            <p class="text-md font-semibold text-slate-800">記録する</p>
          </div>
          <p class="text-sm text-slate-600">ログインして➕記録マークで手軽に記録</p>
          <p class="text-sm text-slate-600">食べたら実食記録。大切な人へ贈ったら贈答記録。</p>
        </div>
        <div class="border border-slate-200 rounded-xl shadow-sm px-4 py-3 space-y-5 ">
          <div class="flex gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
            </svg>
            <p class="text-md font-semibold text-slate-800">好きなときに振り返る</p>
          </div>
            <p class="text-sm text-slate-600">次回購入時の参考に。</p>
            <p class="text-sm text-slate-600">アルバム感覚で眺めて幸せ補充にも◎</p>
        </div>
      </div>
    </div>

    <!-- ユーザー登録/ログイン -->
    <div class="flex justify-center gap-6 my-10 ">
      <%= link_to "ユーザー登録", new_user_registration_path, class: "bg-amber-900 text-white px-4 py-2 rounded-md text-sm hover:bg-amber-800" %>
      <%= link_to "ログイン", new_user_session_path, class: "bg-amber-900 text-white px-4 py-2 rounded-md text-sm hover:bg-amber-800" %>
    </div>
  </section>
</div>
